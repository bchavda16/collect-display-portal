# ============================================================
# collect&display Distribution Portal — Environment Variables
# Copy this file to .env.local and fill in your values
# NEVER commit .env.local to version control
# ============================================================

# ── DATABASE ─────────────────────────────────────────────────
# PostgreSQL connection string (Supabase, Railway, Neon, etc.)
DATABASE_URL="postgresql://user:password@host:5432/collectdisplay?schema=public"

# ── NEXTAUTH ─────────────────────────────────────────────────
# Generate with: openssl rand -base64 32
NEXTAUTH_SECRET="your-secret-here"
NEXTAUTH_URL="http://localhost:3000"

# ── SUPABASE (for file storage) ──────────────────────────────
NEXT_PUBLIC_SUPABASE_URL="https://your-project.supabase.co"
NEXT_PUBLIC_SUPABASE_ANON_KEY="your-anon-key"
SUPABASE_SERVICE_ROLE_KEY="your-service-role-key"

# Supabase storage bucket names
SUPABASE_BUCKET_PRODUCTS="product-images"
SUPABASE_BUCKET_INVOICES="invoices"
SUPABASE_BUCKET_IMPORTS="bulk-imports"

# ── EMAIL (Resend) ───────────────────────────────────────────
RESEND_API_KEY="re_your_key_here"
EMAIL_FROM="orders@collectanddisplay.com"
EMAIL_FROM_NAME="collect&display"
ADMIN_EMAIL="admin@collectanddisplay.com"

# ── APP ──────────────────────────────────────────────────────
NEXT_PUBLIC_APP_URL="http://localhost:3000"
NEXT_PUBLIC_APP_NAME="collect&display Portal"

# VAT rate (UK standard = 0.20)
NEXT_PUBLIC_VAT_RATE="0.20"

# Company info (used in emails and PDFs)
COMPANY_NAME="Collect and Display Ltd"
COMPANY_ADDRESS_LINE1="Unit 1, Warehouse Lane"
COMPANY_ADDRESS_LINE2="Birmingham"
COMPANY_POSTCODE="B1 1AA"
COMPANY_PHONE="+44 121 000 0000"
COMPANY_VAT="GB123456789"
COMPANY_REG="12345678"

# ── RATE LIMITING ────────────────────────────────────────────
# Using Upstash Redis for rate limiting (optional but recommended)
UPSTASH_REDIS_REST_URL="https://your-redis.upstash.io"
UPSTASH_REDIS_REST_TOKEN="your-token"

# Login attempts: max 5 per 15 minutes per IP
RATE_LIMIT_LOGIN_MAX="5"
RATE_LIMIT_LOGIN_WINDOW_SECONDS="900"

# ── ANALYTICS (optional) ─────────────────────────────────────
# NEXT_PUBLIC_POSTHOG_KEY=""
# NEXT_PUBLIC_POSTHOG_HOST="https://eu.posthog.com"
